generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Mines Alès CyberNotes credentials (AES-256 encrypted)
  minesId          String?
  minesPasswordEnc String?
  lastSync         DateTime?
  academicPath     String    @default("DL") // "DL" or "SR"

  accounts Account[]
  sessions Session[]
  grades   Grade[]
  pushSubscriptions PushSubscription[]
}

model Event {
  id          String   @id @default(cuid())
  path        String   // e.g. "DL" or "SR"
  icsUid      String
  summary     String
  description String?
  location    String?
  start       DateTime
  end         DateTime
  updatedAt   DateTime @default(now()) @updatedAt

  @@unique([path, icsUid])
  @@index([path, start])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// Academic structure
model Grade {
  id          String   @id @default(cuid())
  userId      String
  semester    String   // e.g. "S5", "S6"
  ueCode      String   // e.g. "5.1 MATH"
  ueName      String   // e.g. "Mathématiques Outils et Concepts"
  subjectName String
  coefficient Float
  value       Float?   // null if not yet graded
  gradeType   String?  // "Examen", "CC", etc.
  scrapedAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, semester, ueCode, subjectName, gradeType])
  @@index([userId, semester])
}

model CurriculumSubject {
  id          String @id @default(cuid())
  semester    String // e.g. "S5"
  path        String @default("COMMON") // "COMMON", "DL", "SR"
  ueCode      String // e.g. "5.1 MATH"
  ueName      String // e.g. "Mathématiques Outils et Concepts"
  subjectName String // e.g. "Mathématiques pour l'ingénieur"
  coefficient Float

  @@unique([semester, path, ueCode, subjectName])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CantinaMenu {
  id        String   @id @default(cuid())
  weekStart DateTime @unique  // Monday of the week
  data      Json     // { days: [{ name: 'Lundi', plats: [...], accompagnements: [...] }, ...] }
  fetchedAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
