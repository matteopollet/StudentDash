# Database
DATABASE_URL="postgresql://user:password@localhost:5432/studentdash"

# NextAuth
AUTH_SECRET="generate-a-secure-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Encryption key for storing academic credentials (AES-256, 32 bytes hex)
ENCRYPTION_KEY="your-32-bytes-hex-encryption-key-here"

# Web Push VAPID Keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"

# Cron Job Secret
CRON_SECRET="your-cron-secret-key"

# Admin Configuration
ADMIN_EMAIL="admin@example.com"
